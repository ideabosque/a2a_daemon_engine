# AI A2A Daemon Engine - Test Environment Variables
# Copy this file to .env and update with your test configuration

# =============================================================================
# AWS Configuration (for testing)
# =============================================================================
# AWS Region
region_name=us-east-1
AWS_DEFAULT_REGION=us-east-1

# AWS Credentials (use standard AWS environment variable names)
AWS_ACCESS_KEY_ID=test-access-key-id
AWS_SECRET_ACCESS_KEY=test-secret-access-key

# Alternative format (for legacy compatibility)
aws_access_key_id=test-access-key-id
aws_secret_access_key=test-secret-access-key

# Optional: AWS Session Token (for temporary credentials)
# AWS_SESSION_TOKEN=

# Optional: AWS Profile (if using named profiles)
# AWS_PROFILE=default

# =============================================================================
# A2A Daemon Engine Configuration
# =============================================================================
# Endpoint identifier for this A2A daemon instance
endpoint_id=test-endpoint

# Partition identifier for multi-tenant setups
part_id=test-part

# Transport protocol (http, https, grpc)
transport=http

# Server port
port=8001

# Initialize database tables on startup (0=no, 1=yes)
# For tests, typically set to 0 to avoid DB operations
initialize_tables=0

# =============================================================================
# Test Filtering Options
# =============================================================================
# Run only tests matching this exact function name
# Example: AI_A2A_TEST_FUNCTION=test_register_agent_mock
AI_A2A_TEST_FUNCTION=

# Run only tests with these markers (comma or space separated)
# Example: AI_A2A_TEST_MARKERS=unit,a2a
# Available markers: unit, integration, slow, a2a, agent, task, message, server
AI_A2A_TEST_MARKERS=

# =============================================================================
# Logging Configuration
# =============================================================================
# Log level for tests (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# =============================================================================
# Optional: Database Configuration (if running integration tests)
# =============================================================================
# DynamoDB endpoint (leave empty for AWS, or set to local endpoint)
# dynamodb_endpoint=http://localhost:8000

# Table name prefix for test tables
# table_prefix=test_

# =============================================================================
# Optional: External Service Configuration
# =============================================================================
# API Gateway configuration (if testing with actual API Gateway)
# api_id=
# api_stage=dev

# S3 configuration (if testing file operations)
# funct_bucket_name=
# funct_zip_path=
# funct_extract_path=

# SQS configuration (if testing task queues)
# task_queue_name=

# =============================================================================
# Optional: Full Lifecycle Testing
# =============================================================================
# Run full lifecycle flows including deletion (0=no, 1=yes)
# Setting to 0 speeds up tests by skipping cleanup operations
# full_lifecycle_flow=0

# =============================================================================
# Optional: MCP Server Configuration (if testing MCP integration)
# =============================================================================
# mcp_server_url=http://localhost:9000
# bearer_token=
# x-api-key=

# =============================================================================
# Optional: Connection Configuration
# =============================================================================
# WebSocket connection ID (if testing WebSocket features)
# connection_id=

# Execution mode (local_for_all, lambda, mixed)
# execute_mode=local_for_all
