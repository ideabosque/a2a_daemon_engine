# =============================================================================
# A2A Daemon Engine - Integration Test Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# IMPORTANT: Never commit .env with real credentials to version control.
# =============================================================================

# --- Base ---
base_dir=C:/Users/bibo7/gitrepo/silvaengine

# --- AWS Configuration ---
# Required for DynamoDB mode. In PostgreSQL mode, AWS credentials are optional
# (S3 and Lambda stay initialized from the default credential chain when these
# are absent).
region_name=us-east-1
aws_access_key_id=your_aws_access_key_id
aws_secret_access_key=your_aws_secret_access_key

# --- A2A Daemon Runtime ---
A2A_TRANSPORT=http
PORT=8001

# --- Auth Configuration ---
# AUTH_PROVIDER: "local" (default) or "cognito"
AUTH_PROVIDER=local
# JWT_SECRET_KEY: required for AUTH_PROVIDER=local. Must be >= 32 chars and
# not a default/weak value (e.g. CHANGEME, secret, password).
JWT_SECRET_KEY=replace-me-with-a-strong-random-secret-of-32-or-more-chars
# LOCAL_USER_FILE=users.json                 # Optional: local user store
# ADMIN_STATIC_TOKEN=                        # Optional: pre-generated admin bypass token

# --- Cognito (when AUTH_PROVIDER=cognito) ---
# COGNITO_USER_POOL_ID=us-west-2_xxx
# COGNITO_APP_CLIENT_ID=xxx
# COGNITO_APP_SECRET=xxx
# COGNITO_JWKS_URL=                          # Optional: override JWKS endpoint

# --- Tenant Partition ---
# endpoint_id and part_id together form the partition_key ({endpoint_id}#{part_id}).
# All persistence and GraphQL queries flow through this composite key, so
# cross-tenant access is hard-isolated at the row level.
endpoint_id=test-endpoint
part_id=test-part

# --- Execution ---
# initialize_tables: 0=no table creation, 1=create tables on startup
# For unit tests, typically set to 0 to avoid DB operations.
initialize_tables=0
# execute_mode: local_for_all | lambda | mixed
# execute_mode=local_for_all

# --- Phase 10: ai_agent_core_engine bridge (optional) ---
# A2A_AI_AGENT_MODULE=my_engine.handlers.llm_handler
# A2A_AI_AGENT_CLASS=LLMHandler
# A2A_DEFAULT_AGENT_UUID=a2a-default-agent
# A2A_STREAMING_ENABLED=true
# A2A_STREAM_TIMEOUT=120.0

# --- Live API Tests ---
# Set A2A_RUN_LIVE_API_TESTS=1 to run tests/test_api.py against a running daemon.
# A2A_RUN_LIVE_API_TESTS=1

# --- Test Filtering Options ---
# Run only tests matching this exact function name
# AI_A2A_TEST_FUNCTION=test_graphql_ping
# Run only tests with these markers (comma or space separated)
# Available markers: unit, integration, slow, a2a, agent, task, message, server, graphql, cache, performance
# AI_A2A_TEST_MARKERS=unit,a2a

# --- Logging ---
LOG_LEVEL=INFO

# --- DynamoDB (used when db_backend=dynamodb) ---
# Leave dynamodb_endpoint empty for AWS, or set to a local endpoint:
# dynamodb_endpoint=http://localhost:8000
# table_prefix=test_

# --- Dual-Backend Selection ---
# db_backend: "dynamodb" (default) or "postgresql"
# When set to "postgresql", the PG_* keys below are used and DynamoDB
# table creation is skipped. Install the PG extra first:
#   pip install a2a-daemon-engine[postgresql]
db_backend=dynamodb

# --- PostgreSQL connection (used when db_backend=postgresql) ---
# Either DATABASE_URL or the PG_* keys below. When DATABASE_URL is set it wins.
# DATABASE_URL=postgresql+psycopg2://a2a_daemon:password@localhost:5432/a2a_daemon_engine
PG_HOST=localhost
PG_PORT=5432
PG_USER=silvaengine
PG_PASSWORD=silvaengine
PG_DB=silvaengine